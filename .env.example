# Copy this file to .env and customize values

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR

# Weather API (Open-Meteo - no key needed)
WEATHER_CACHE_TTL=600    # seconds

# Vercel Deployment (set in CI/CD secrets)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
